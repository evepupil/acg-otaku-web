# Database (required)
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your_turso_auth_token"

# Pixiv access (required for admin artwork import)
PIXIV_COOKIE="your_pixiv_cookie"

# B2 object storage (required for admin image upload)
B2_APPLICATION_KEY_ID="your_b2_key_id"
B2_APPLICATION_KEY="your_b2_key"
B2_BUCKET_NAME="your_b2_bucket_name"
B2_BUCKET_ID="your_b2_bucket_id"
B2_ENDPOINT="https://s3.us-east-005.backblazeb2.com"

# Public image URLs used by frontend
NEXT_PUBLIC_B2_BUCKET_URL="https://pixiv-b2-bucket.acgotaku.com"
NEXT_PUBLIC_PROXY_SERVER="https://pixiv-b2-bucket.acgotaku.com"
CRAWLER_SERVER_URL="http://43.153.149.111:3000"

# Admin auth (required for /admin)
ADMIN_PASSWORD="your_admin_password"
ADMIN_JWT_SECRET="your_admin_jwt_secret"

# Optional integrations
SAUCENAO_API_KEY=""
